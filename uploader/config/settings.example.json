{
    "watch_interval_seconds": 60,
    "sources": [
        {
            "type": "milking_robot",
            "collection": "milking_controle_data",
            "data_directory": "../data",
            "file_pattern": "*.txt"
        },
        {
            "type": "feed_distribution",
            "collection": "feed_distribution_data",
            "data_directory": "../data",
            "file_pattern": "Voerdistributie-rapport*.csv"
        },
        {
            "type": "production_report",
            "collection": "milking_production_data",
            "data_directory": "../data",
            "file_pattern": "Productie-rapport*.csv"
        }
    ],
    "vault": {
        "mode": "evault",
        "local_path": "../evault_local",
        "registry_url": "https://registry.w3ds.metastate.foundation",
        "w3id": "@your-farm-ename",
        "platform": "melkmonitor-uploader",
        "schema_ids": {
            "milking_controle_data": "milking_controle_data",
            "feed_distribution_data": "feed_distribution_data",
            "milking_production_data": "milking_production_data"
        }
    }
}
