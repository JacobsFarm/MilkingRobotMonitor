# Local test vault (generated data, not source)
evault_local/

# Raw milk control data (private farm data — never commit)
data/*
!data/README.md

# Real settings and credentials — never commit (use the .example templates)
**/config/settings.json
**/config/epassport.json

# Uploader sync state (which record ids are already uploaded) — machine-local
uploader/state/

# Agent's and chatbot's local copies of vault collections — machine-local, re-fetchable
agent/cache/
agent_chatbot/cache/

# Build output (PyInstaller .exe AND SvelteKit adapter-node both use build/ and dist/)
build/
dist/
*.spec

# Node / SvelteKit
node_modules/
.svelte-kit/
.vite/
*.timestamp-*
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/

# Environments
.venv
env/
venv/
ENV/

# Editors / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
